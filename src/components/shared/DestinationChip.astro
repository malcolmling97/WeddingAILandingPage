---
interface Props {
  label: string;
  class?: string;
}
const { label, class: className } = Astro.props;
---

<span class:list={['chip', 'chip--teal', 'dest-chip', className]}>{label}</span>

<style>
  @media (prefers-reduced-motion: no-preference) {
    :global(.js) [data-reveal].is-in .dest-chip,
    :global(.js) [data-reveal].is-in.dest-chip {
      animation: stamp 350ms cubic-bezier(0.34, 1.56, 0.64, 1) both;
      animation-delay: 250ms;
    }
  }

  @keyframes stamp {
    from {
      opacity: 0;
      transform: scale(1.4) rotate(-4deg);
    }
    to {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
  }
</style>

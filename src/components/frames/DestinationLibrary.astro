---
import { Image } from 'astro:assets';
import { copy } from '../../content/copy';
import { images } from '../../content/images';
import DestinationChip from '../shared/DestinationChip.astro';
---

<section class="section destinations">
  <div class="section-inner">
    <h2>{copy.destinations.header}</h2>
    <div class="grid">
      {
        copy.destinations.cards.map((card, i) => {
          const img = images.destinations[card.key];
          return (
            <figure class="card dest-card" data-reveal style={`--d: ${i * 100}ms;`}>
              <Image src={img.src} alt={img.alt} loading="lazy" widths={[480, 960]} sizes="(min-width: 900px) 220px, 45vw" />
              <figcaption>
                <DestinationChip label={card.tag} />
                <p class="caption">{card.caption}</p>
              </figcaption>
            </figure>
          );
        })
      }
      <div class="dest-card custom" data-reveal style="--d: 400ms;">
        <div class="custom-inner">
          <DestinationChip label={copy.destinations.customCard.tag} />
          <p class="caption">{copy.destinations.customCard.caption}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .dest-card {
    overflow: hidden;
    border-radius: var(--radius);
  }

  figcaption,
  .custom-inner {
    padding: var(--space-2);
  }

  .caption {
    margin-top: var(--space-1);
    font-size: 0.95rem;
  }

  .custom {
    border: 2px dashed var(--ink);
    border-radius: var(--radius);
    display: grid;
    place-items: center;
    text-align: center;
    min-height: 12rem;
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .dest-card {
      transition: transform 200ms ease;
    }

    .dest-card:hover {
      transform: rotate(-1.5deg) scale(1.02);
    }
  }

  @media (min-width: 900px) {
    .grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }
</style>

---
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/instrument-sans';
import '@fontsource-variable/shantell-sans';
import bricolageUrl from '@fontsource-variable/bricolage-grotesque/files/bricolage-grotesque-latin-wght-normal.woff2?url';
import instrumentUrl from '@fontsource-variable/instrument-sans/files/instrument-sans-latin-wght-normal.woff2?url';
import '../styles/global.css';
import { copy } from '../content/copy';
import Footer from '../components/shared/Footer.astro';

const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const ogImage = Astro.site ? new URL('/og.png', Astro.site).href : '/og.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{copy.meta.title}</title>
    <meta name="description" content={copy.meta.description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta name="theme-color" content="#FBF6EE" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={copy.meta.title} />
    <meta property="og:description" content={copy.meta.description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preload" as="font" type="font/woff2" href={bricolageUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={instrumentUrl} crossorigin />

    <script is:inline>
      document.documentElement.classList.add('js');
      window.plausible =
        window.plausible ||
        function () {
          (window.plausible.q = window.plausible.q || []).push(arguments);
        };
    </script>
    <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.js"></script>
    <script src="../scripts/motion.ts"></script>
    <slot name="head" />
  </head>
  <body>
    <slot />
    <Footer />
  </body>
</html>
